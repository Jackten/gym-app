# App
APP_NAME=gym-app
APP_ENV=development
APP_URL=http://localhost:3000

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/gym_app

# Auth (select/implement later)
AUTH_MODE=basic
SESSION_SECRET=replace_me

# Pricing config (initial defaults)
DEMAND_WINDOW_WEEKS=12
DEMAND_MULTIPLIER_LOW=1.00
DEMAND_MULTIPLIER_MEDIUM=1.05
DEMAND_MULTIPLIER_HIGH=1.10
DEMAND_MULTIPLIER_VERY_HIGH=1.15

OCCUPANCY_UPLIFT_AFTER_2=true
OCCUPANCY_MULTIPLIER_1=1.00
OCCUPANCY_MULTIPLIER_2=1.00
OCCUPANCY_MULTIPLIER_3=1.05
OCCUPANCY_MULTIPLIER_4=1.10
OCCUPANCY_MULTIPLIER_5=1.15

MAX_CONCURRENT_CAPACITY=5
QUOTE_LOCK_MINUTES=5

# Payments (future)
PAYMENT_PROVIDER=
PAYMENT_API_KEY=

# Notifications (future)
EMAIL_FROM=
SMTP_URL=
